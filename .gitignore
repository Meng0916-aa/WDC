# Python cache
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environments
.venv/
venv/
env/
*.env
.env

# Local database (binary db excluded; .gitkeep preserved)
database/*.db
database/*.sqlite
database/*.sqlite3
!database/.gitkeep

# Camera calibration files (vendor-specific; do not publish)
*.tcal
*.nuc
*.dp

# Local Claude settings & skills (user's local tooling, not project content)
.claude/

# OS / editor
.DS_Store
Thumbs.db
.vscode/

# Note: data/raw, data/processed, data/features, results/figures and
# *.xtherm / *.npz / *.csv / *.png are now versioned through Git LFS
# (see .gitattributes). The previous wildcard exclusions for those
# directories have been removed to allow LFS-tracked uploads.
